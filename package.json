{
	"name": "1o1-utils",
	"version": "1.4.0",
	"description": "A collection of utility functions for TypeScript & Javascript",
	"license": "MIT",
	"type": "module",
	"types": "dist/index.d.ts",
	"sideEffects": false,
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./array-to-hash": {
			"import": "./dist/arrays/array-to-hash/index.js",
			"types": "./dist/arrays/array-to-hash/index.d.ts"
		},
		"./chunk": {
			"import": "./dist/arrays/chunk/index.js",
			"types": "./dist/arrays/chunk/index.d.ts"
		},
		"./group-by": {
			"import": "./dist/arrays/group-by/index.js",
			"types": "./dist/arrays/group-by/index.d.ts"
		},
		"./clone-deep": {
			"import": "./dist/objects/clone-deep/index.js",
			"types": "./dist/objects/clone-deep/index.d.ts"
		},
		"./deep-merge": {
			"import": "./dist/objects/deep-merge/index.js",
			"types": "./dist/objects/deep-merge/index.d.ts"
		},
		"./omit": {
			"import": "./dist/objects/omit/index.js",
			"types": "./dist/objects/omit/index.d.ts"
		},
		"./pick": {
			"import": "./dist/objects/pick/index.js",
			"types": "./dist/objects/pick/index.d.ts"
		},
		"./sort-by": {
			"import": "./dist/arrays/sort-by/index.js",
			"types": "./dist/arrays/sort-by/index.d.ts"
		},
		"./is-empty": {
			"import": "./dist/objects/is-empty/index.js",
			"types": "./dist/objects/is-empty/index.d.ts"
		},
		"./sleep": {
			"import": "./dist/async/sleep/index.js",
			"types": "./dist/async/sleep/index.d.ts"
		},
		"./retry": {
			"import": "./dist/async/retry/index.js",
			"types": "./dist/async/retry/index.d.ts"
		},
		"./capitalize": {
			"import": "./dist/strings/capitalize/index.js",
			"types": "./dist/strings/capitalize/index.d.ts"
		},
		"./debounce": {
			"import": "./dist/async/debounce/index.js",
			"types": "./dist/async/debounce/index.d.ts"
		},
		"./slugify": {
			"import": "./dist/strings/slugify/index.js",
			"types": "./dist/strings/slugify/index.d.ts"
		},
		"./throttle": {
			"import": "./dist/async/throttle/index.js",
			"types": "./dist/async/throttle/index.d.ts"
		},
		"./transform-case": {
			"import": "./dist/strings/transform-case/index.js",
			"types": "./dist/strings/transform-case/index.d.ts"
		},
		"./truncate": {
			"import": "./dist/strings/truncate/index.js",
			"types": "./dist/strings/truncate/index.d.ts"
		}
	},
	"scripts": {
		"test": "mocha",
		"test:coverage": "c8 mocha",
		"build": "tsc",
		"dev": "tsx watch src/index.ts",
		"lint": "biome lint ./src",
		"format": "biome format --write ./src",
		"check": "biome check ./src",
		"check:fix": "biome check --write ./src",
		"bench": "NODE_OPTIONS='--max-old-space-size=8192' tsx src/benchmarks/run.ts",
		"size": "size-limit",
		"size:json": "size-limit --json",
		"docs:dev": "cd website && pnpm dev",
		"docs:build": "cd website && pnpm build",
		"docs:preview": "cd website && pnpm preview"
	},
	"packageManager": "pnpm@10.9.0",
	"engines": {
		"node": ">=20"
	},
	"publishConfig": {
		"registry": "https://registry.npmjs.org",
		"provenance": true
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@changesets/cli": "^2.30.0",
		"@size-limit/file": "^12.0.1",
		"@size-limit/preset-small-lib": "^12.0.1",
		"@types/chai": "^5.2.2",
		"@types/lodash": "^4.17.24",
		"@types/mocha": "^10.0.10",
		"c8": "^11.0.0",
		"chai": "^5.3.1",
		"lodash": "^4.18.1",
		"mocha": "^11.7.1",
		"radash": "^12.1.1",
		"size-limit": "^12.0.1",
		"tinybench": "^6.0.0",
		"ts-node": "^10.9.2",
		"tsx": "^4.20.4",
		"typescript": "^5.9.2"
	}
}
